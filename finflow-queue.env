CLIENT_API_KEY=
NODE_API_KEYS_JSON={"kaggle-1":"","lightning-1":"","colab-1":""}
QUEUE_DB_PATH=/home/opc/finflow-queue/finflow_queue.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 真實公開 IP，setup-https.sh 與 Caddyfile 都從這裡讀取（見
# setup-https.sh 步驟 0、4，以及 Caddyfile 的 {$ORACLE_PUBLIC_IP}），
# 不要把它寫死進 Caddyfile 或 setup-https.sh 本身
ORACLE_PUBLIC_IP=

# ── 以下為 bot-gateway.service 專用的機敏設定 ──
# 原本個別寫在 bot-gateway.service 的 Environment= 裡，明碼常駐在該檔案中；
# 統一搬進這裡管理，往後輪替金鑰、查找設定只需要看這一份檔案。
# TELEGRAM_BOT_TOKEN 跟上面 server.py 用的是同一個變數名稱——如果你的
# Telegram 告警 Bot 跟使用者互動的 Bot 是同一個，填一次即可兩邊共用；
# 如果你想用兩個不同的 Bot，把上面那組另外複製一份改名（例如
# TELEGRAM_ALERT_BOT_TOKEN）並同步修改 server.py 讀取的變數名稱。
TELEGRAM_WEBHOOK_SECRET=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
DISCORD_PUBLIC_KEY=
