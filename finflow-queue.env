CLIENT_API_KEY=
NODE_API_KEYS_JSON={"kaggle-1":"","lightning-1":"","colab-1":""}
QUEUE_DB_PATH=/home/opc/finflow-queue/finflow_queue.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 真實公開 IP，setup-https.sh 與 Caddyfile 都從這裡讀取（見
# setup-https.sh 步驟 0、4，以及 Caddyfile 的 {$ORACLE_PUBLIC_IP}），
# 不要把它寫死進 Caddyfile 或 setup-https.sh 本身
ORACLE_PUBLIC_IP=

# 選填：只有走 Step 4-A（Cloudflare 代管憑證）時才需要填。Caddyfile 的
# 站台位址列表已經在用 {$DOMAIN_NAME}（見 Caddyfile 第 30 行），跟
# ORACLE_PUBLIC_IP 同一套機制——填在這裡、不寫死進 Caddyfile，重啟 caddy
# 服務即可生效（caddy-override.conf 已經把整份 finflow-queue.env 餵給
# caddy.service，不需要額外設定）。沒有網域、只用方案 A 自簽憑證的話留空即可。
DOMAIN_NAME=

# ── 以下為 bot-gateway.service 專用的機敏設定 ──
# 原本個別寫在 bot-gateway.service 的 Environment= 裡，明碼常駐在該檔案中；
# 統一搬進這裡管理，往後輪替金鑰、查找設定只需要看這一份檔案。
# TELEGRAM_BOT_TOKEN 跟上面 server.py 用的是同一個變數名稱——如果你的
# Telegram 告警 Bot 跟使用者互動的 Bot 是同一個，填一次即可兩邊共用；
# 如果你想用兩個不同的 Bot，把上面那組另外複製一份改名（例如
# TELEGRAM_ALERT_BOT_TOKEN）並同步修改 server.py 讀取的變數名稱。
TELEGRAM_WEBHOOK_SECRET=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
DISCORD_PUBLIC_KEY=

# ── 以下為節點群控功能專用（/start-node、/stop-node、/list-nodes）──
# 這是另一個獨立的 Discord bot（跟上面 DISCORD_PUBLIC_KEY 那個 /ask bot
# 不是同一個 Application），刻意分開是為了權限分離：一般使用者只該看到
# /ask，節點的開關不該讓每個能問問題的人都能操作。詳見 DEPLOY.md「節點
# 群控」章節。
DISCORD_ADMIN_PUBLIC_KEY=

# node_id -> 平台設定的對照表，JSON 格式。Kaggle 節點要填 kernel_slug
# （對應 kaggle kernels push 的 kernel-metadata.json 裡的 id 後半段），
# accelerator 選填（例如 "NvidiaTeslaT4"，指定 GPU 型號，不填交給 Kaggle
# 自動分配；目前無法保證拿到「兩張」）；Lightning 節點要填 studio_name、
# teamspace（在 Lightning 後台建立 Studio 時你自己取的名字）。範例：
# NODE_PLATFORM_MAP={"kaggle-1":{"platform":"kaggle","kernel_slug":"finflow-edge-worker-kaggle-1","accelerator":"NvidiaTeslaT4"},"lightning-1":{"platform":"lightning","studio_name":"finflow-edge-1","teamspace":"your-teamspace"}}
NODE_PLATFORM_MAP={}

# Kaggle API 認證（Kaggle 帳號 -> Settings -> API -> Create New Token
# 下載到的 kaggle.json 裡就有這兩個值）。只有 /start-node、/stop-node
# 這兩個指令用得到，一般問答功能完全不需要這兩把。
KAGGLE_USERNAME=
KAGGLE_KEY=

# Lightning AI API 認證（Lightning 後台 -> Settings -> API Keys）
LIGHTNING_USER_ID=
LIGHTNING_API_KEY=

# Lightning 閒置監控：多久沒收到心跳就視為閒置、主動呼叫 Studio.stop()
# 節省費用（Kaggle 沒有對應設定，因為 Kaggle 本來就沒有外部停止 API，
# 閒置偵測只能靠 bootstrap.py 自己的 IDLE_STOP_SEC，見 edge.conf）。
# 不填則使用程式內建預設值（1800 秒／60 秒）。
LIGHTNING_IDLE_TIMEOUT_SEC=1800
LIGHTNING_IDLE_CHECK_INTERVAL_SEC=60
