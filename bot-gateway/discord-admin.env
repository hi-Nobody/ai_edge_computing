# /home/opc/finflow-queue/bot-gateway/discord-admin.env（只有你自己用，不要跟服務共用那份）
#
# 兩組指令分屬兩個不同的 Discord Application（兩個 bot），要各自建立、
# 各自有自己的 Bot Token／Application ID，不能共用同一組。詳見
# register_discord_commands.py 檔頭說明。

# ── /ask（一般問答 bot）──
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# ── /start-node、/stop-node、/list-nodes、/load-node（節點群控 bot）──
DISCORD_ADMIN_BOT_TOKEN=MTUyNzUzMjU2Mjk1OTA0MDUzNA.Gn8FCK.SpHyipsqaHh-PWwRsyYNRG9RT15BSQ6wx_Wf4g
DISCORD_ADMIN_APPLICATION_ID=

# 選填：兩組指令預設都註冊為 Global Command。如果想先在自己的測試伺服器
# 立即生效（不等 Global 的傳播延遲），填這個伺服器的 Guild ID。
# DISCORD_GUILD_ID=

# 不需要在這裡填 NODE_PLATFORM_MAP——register_discord_commands.py 會自動
# 從同一個 repo 根目錄的 finflow-queue.env 讀取（該值本來就要跟 Oracle
# 端維持一致），/start-node、/stop-node 的 node_id 參數會自動變成下拉選單。