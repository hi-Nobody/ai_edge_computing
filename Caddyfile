# FinFlow HTTPS 反向代理設定 —— Caddy
#
# 更新說明：/telegram/*、/line/*、/discord/* 原本指向的 127.0.0.1:8001 沒有
# 任何服務在監聽（或未實作），現在已補上 bot-gateway/bot_gateway.py（見
# bot-gateway/ 目錄），這三條路由可以正常使用了。若尚未部署 bot-gateway，
# 這幾段會回 502，屬預期行為。
#
# 注意：Discord 的 Interactions Endpoint 驗證只接受受信任 CA 簽發的憑證，
# 方案 A（下方的 tls internal 自簽憑證）無法通過 Discord 的端點驗證，
# 要用 Discord 必須改用方案 B 或方案 C（詳見 DEPLOY.md「建立 Discord Bot」小節）。

# 全域選項：caddy 服務帳號不在 sudoers 裡，無法把自簽 CA 安裝進系統信任庫，
# 這裡明確跳過該步驟（本來就用 curl -k / verify=False，不需要系統信任這張憑證）
{
	skip_install_trust
}

# ============================================================
# 方案 A（零成本，預設）：自簽憑證，綁定 Oracle 公開 IP
# 適合：不想花錢買網域、可接受邊緣節點端用 verify=False 連線
#
# {$ORACLE_PUBLIC_IP} 是從 finflow-queue.env 讀進來的環境變數（見
# setup-https.sh 步驟 0、4），真實 IP 不寫死在這個會被 commit 的檔案裡。
# 10.0.0.152 是 VCN 內部私有 IP，非機敏資訊，維持寫死無妨。
# ============================================================

127.0.0.1, 10.0.0.152, {$ORACLE_PUBLIC_IP}, myproj2.dpdns.org {
	tls internal

	handle /telegram/* {
		reverse_proxy 127.0.0.1:8001
	}
	handle /line/* {
		reverse_proxy 127.0.0.1:8001
	}
	handle /discord/* {
		reverse_proxy 127.0.0.1:8001
	}
	handle {
		reverse_proxy 127.0.0.1:8000
	}
}

# ============================================================
# 方案 B（建議，但網域非完全免費，多數註冊商 .com 約 NT$300-400/年）：
# 改用你自己的網域，Caddy 會自動向 Let's Encrypt 申請正式憑證，
# 邊緣節點端可以把 VERIFY_TLS 設回 true，獲得真正的憑證驗證保護。
#
# 啟用方式：刪除上面方案 A 整段，取消下面的註解，並把網域換成你的：
# ============================================================

# your-domain.example.com {
# 	handle /telegram/* {
# 		reverse_proxy 127.0.0.1:8001
# 	}
# 	handle /line/* {
# 		reverse_proxy 127.0.0.1:8001
# 	}
# 	handle /discord/* {
# 		reverse_proxy 127.0.0.1:8001
# 	}
# 	handle {
# 		reverse_proxy 127.0.0.1:8000
# 	}
# }

# ============================================================
# 方案 C（不需要任何網域，也不需要 Oracle 開對外 port，但需要
# 額外安裝 cloudflared）：Cloudflare Tunnel
#
# 運作方式：Oracle 主動對外連到 Cloudflare 的網路（outbound only），
# Cloudflare 提供公開的 HTTPS 入口，連 Security List 都不用開 443/8000。
# 缺點：仍需要一個掛在 Cloudflare 上的網域（網域本身不是免費的，
#       但 Cloudflare 的 Tunnel 服務本身免費）。
# 設定步驟請見 DEPLOY.md 的「方案 C」章節，這裡的 Caddyfile 不適用，
# 因為流量入口換成 cloudflared，可以省略 Caddy，讓 cloudflared 直接
# 指向 8000（主要 API）與 8001（bot-gateway）。
# ============================================================
